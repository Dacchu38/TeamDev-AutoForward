# ───────────────────
#  TeamDev Auto-Forward Bot — Environment Config
#  Copy this file to .env and fill in values.
#  NEVER commit your actual .env to GitHub!
# ───────────────────

#───────── Required ──────────
# Get from https://my.telegram.org
API_ID=
API_HASH=

# Get from @BotFather on Telegram
BOT_TOKEN=

# Your own Telegram user ID (numeric)
# Get it from @userinfobot or @RawDataBot
OWNER_ID=

# MongoDB Atlas connection string
# Format: mongodb+srv://user:pass@cluster.mongodb.net/?appName=Cluster0
MONGO_URI=

#────────── Optional ──────────
# Channel or group for activity logs (e.g. @mychannel or -100123456789)
LOG_CHANNEL=

# Max messages forwarded per minute per pipeline (default: 20)
RATE_LIMIT=100

# Number of concurrent forward workers (default: 4)
WORKERS=4

# I'm Recommending To Leave It As!
FORCE_JOIN=
